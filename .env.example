# Required ----------------------------------------------------------------
TINKER_API_KEY=         # https://tinker-console.thinkingmachines.ai
HF_TOKEN=               # https://huggingface.co/settings/tokens

# Set after each RL stage finishes (URIs printed by the training run) ----
# Stage 1: rl_multipersona_gsm8k.sh writes a session whose final checkpoint
# you'll need for stage 2 and for any GSM8K-checkpoint-anchored evals.
# PANEL_GSM8K_CHECKPOINT=tinker://<your-session>:train:0/weights/final
# PANEL_GSM8K_CHECKPOINT_SAMPLER=tinker://<your-session>:train:0/sampler_weights/final

# Stage 2: rl_multipersona_math.sh writes a session whose final checkpoint
# is the panel-MATH adapter — required as the init for the olympiad RL,
# and as the sampler URI for post-MATH evaluation sweeps.
# PANEL_MATH_CHECKPOINT=tinker://<your-session>:train:0/weights/final
# PANEL_MATH_CHECKPOINT_SAMPLER=tinker://<your-session>:train:0/sampler_weights/final

# Optional ---------------------------------------------------------------
# If `tinker_cookbook` is checked out as a sibling directory rather than
# pip-installed, point this at it so scripts that import it can find the
# source. Unset = scripts rely on whatever the active venv resolves.
# TINKER_COOKBOOK_PATH=/path/to/tinker-cookbook
